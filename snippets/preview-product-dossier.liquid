{% liquid
  assign preview_title_text = preview_title | default: 'Copper Pour-Over Kettle With a Bottle-Shaped Silhouette'
  assign preview_material_note = material_note | default: 'Copper body'
  assign preview_notify_tag = notify_tag | default: 'notify-copper-bottle-pour-over-kettle'
  assign preview_media_badge_text = media_badge | default: 'Reference image / placeholder'
  assign preview_notify_anchor = notify_anchor_id | default: 'notify-interest'
  assign preview_media_alt_text = media_alt | default: preview_title_text | append: ' preview image'
  assign preview_kicker_text = preview_kicker | default: 'Non-silver-lined version. Catalog-listed specs. Pending sample review.'
%}

{% render 'preview-launch-theme' %}

<style>
  .preview-product {
    padding: 40px 0 82px;
  }

  .preview-product__status,
  .preview-product__layout,
  .preview-product__highlights,
  .preview-product__detail-grid,
  .preview-product__faq {
    margin-bottom: 24px;
  }

  .preview-product__status {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) auto;
    gap: 18px;
    align-items: center;
    padding: 20px 24px;
  }

  .preview-product__status-copy {
    display: grid;
    gap: 14px;
  }

  .preview-product__status-copy p {
    margin: 0;
    color: var(--lp-muted);
    font-size: 15px;
    line-height: 1.7;
  }

  .preview-product__status-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .preview-product__layout,
  .preview-product__highlights,
  .preview-product__detail-grid,
  .preview-product__faq-grid {
    display: grid;
    gap: 24px;
  }

  .preview-product__layout {
    grid-template-columns: minmax(0, 0.98fr) minmax(360px, 1.02fr);
    align-items: stretch;
  }

  .preview-product__media-panel,
  .preview-product__details,
  .preview-product__section,
  .preview-product__faq {
    padding: 30px;
  }

  .preview-product__media-frame {
    min-height: 620px;
  }

  .preview-product__media-note {
    margin-top: 14px;
  }

  .preview-product__details {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .preview-product__details p {
    margin: 0;
  }

  .preview-product__summary,
  .preview-product__boundary,
  .preview-product__notify {
    display: grid;
    gap: 14px;
  }

  .preview-product__summary {
    margin-top: 2px;
  }

  .preview-product__boundary,
  .preview-product__notify {
    padding: 22px;
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-sm);
    background: var(--lp-surface-strong);
  }

  .preview-product__boundary ul {
    margin: 0;
    padding-left: 20px;
  }

  .preview-product__notify-form {
    display: grid;
    gap: 12px;
  }

  .preview-product__notify-messages {
    display: grid;
    gap: 8px;
  }

  .preview-product__message {
    margin: 0;
    font-size: 13px;
    line-height: 1.7;
  }

  .preview-product__message.is-success {
    color: #2f6f3e;
  }

  .preview-product__message.is-error {
    color: #a94442;
  }

  .preview-product__highlights {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .preview-product__detail-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .preview-product__section p {
    margin: 0;
  }

  .preview-product__section-copy {
    display: grid;
    gap: 14px;
    margin-bottom: 18px;
  }

  .preview-product__spec-status {
    padding-left: 18px;
  }

  .preview-product__faq-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .preview-product__faq-link {
    margin-top: 16px;
  }

  @media screen and (max-width: 989px) {
    .preview-product__status,
    .preview-product__layout,
    .preview-product__detail-grid,
    .preview-product__faq-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .preview-product__highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .preview-product__media-frame {
      min-height: 380px;
    }
  }

  @media screen and (max-width: 749px) {
    .preview-product {
      padding: 28px 0 56px;
    }

    .preview-product__media-panel,
    .preview-product__details,
    .preview-product__section,
    .preview-product__faq,
    .preview-product__status {
      padding: 22px;
    }

    .preview-product__highlights {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

<section class="launch-preview preview-product">
  <div class="launch-preview__container">
    <div class="launch-preview__surface launch-preview__surface--tight preview-product__status">
      <div class="preview-product__status-copy">
        <div class="launch-preview__chip-row">
          <span class="launch-preview__chip launch-preview__chip--accent">Product Preview</span>
          <span class="launch-preview__chip">Notify Only</span>
          <span class="launch-preview__chip launch-preview__chip--sage">No Live Checkout</span>
        </div>
        <p>Shown with reference imagery and catalog-listed details while sample review is still pending.</p>
      </div>
      <div class="preview-product__status-links">
        <a href="/pages/preview-stage">Preview Terms</a>
        <a href="/pages/faq">FAQ</a>
      </div>
    </div>

    <div class="preview-product__layout">
      <div class="launch-preview__surface preview-product__media-panel">
        <div class="launch-preview__media-frame preview-product__media-frame">
          <span class="launch-preview__badge">{{ preview_media_badge_text }}</span>
          {%- if preview_featured_image != blank -%}
            {{ preview_featured_image | image_url: width: 1600 | image_tag: alt: preview_media_alt_text, loading: 'lazy' }}
          {%- else -%}
            <div class="launch-preview__placeholder">
              <div>
                <strong>Preview image slot is ready.</strong>
                <p style="margin: 10px 0 0;">Use a clearly labeled reference image or placeholder until review-backed photography is available.</p>
              </div>
            </div>
          {%- endif -%}
        </div>
        <p class="launch-preview__fineprint preview-product__media-note">Reference imagery only. Final close-up detail photography will be added after sample review.</p>
      </div>

      <div class="launch-preview__surface preview-product__details">
        <p class="launch-preview__eyebrow">Product Preview</p>
        <h1 class="launch-preview__title launch-preview__title--lg">{{ preview_title_text }}</h1>
        <p class="launch-preview__lead">{{ preview_kicker_text }}</p>
        <div class="launch-preview__chip-row">
          <span class="launch-preview__chip">{{ preview_material_note }}</span>
          <span class="launch-preview__chip">Non-silver-lined version</span>
          <span class="launch-preview__chip launch-preview__chip--sage">Single-SKU focus</span>
        </div>

        <div class="launch-preview__body preview-product__summary">
          {%- if preview_description_html != blank -%}
            {{ preview_description_html }}
          {%- else -%}
            <p>This preview centers on the non-silver-lined version and the catalog-listed dimensions currently available to share.</p>
            <p>It is designed to explain the object, the boundaries, and the only live action now: product updates.</p>
          {%- endif -%}
        </div>

        <div class="preview-product__boundary" data-hidden-modules="price inventory purchase-buttons variants reviews recommendations delivery offers">
          <p class="launch-preview__eyebrow">What Is Not Live Yet</p>
          <ul class="launch-preview__body">
            <li>Pricing, availability, and shipping timing</li>
            <li>Preorder, waitlist, or any reservation mechanic</li>
            <li>Performance, certification, or safety claims</li>
            <li>Final measured details and approved close-up imagery</li>
          </ul>
        </div>

        <div id="{{ preview_notify_anchor }}" class="preview-product__notify">
          <p class="launch-preview__eyebrow">Notify CTA</p>
          <h2 class="launch-preview__title launch-preview__title--md">Notify me when the next review-backed update is live.</h2>
          <p class="launch-preview__lead">Sign up for product updates only. This is not a preorder, waitlist, or purchase commitment.</p>
          {%- form 'customer', class: 'preview-product__notify-form' -%}
            <input type="hidden" name="contact[tags]" value="{{ preview_notify_tag }}">
            <div class="launch-preview__form-row">
              <input class="launch-preview__input" type="email" name="contact[email]" placeholder="Email for product updates" required>
              <button type="submit" class="launch-preview__button">Notify Me</button>
            </div>
            <p class="launch-preview__fineprint">Your email is used for updates on this product only. It does not reserve stock or hold a purchase place.</p>
            <div class="preview-product__notify-messages">
              {%- if form.posted_successfully? -%}
                <p class="preview-product__message is-success">You are signed up for product updates. This does not create a reservation or purchase commitment.</p>
              {%- endif -%}
              {%- if form.errors -%}
                <p class="preview-product__message is-error">Please enter a valid email address before submitting the form.</p>
              {%- endif -%}
            </div>
          {%- endform -%}
        </div>
      </div>
    </div>

    <div class="preview-product__highlights">
      <article class="launch-preview__card">
        <p class="launch-preview__eyebrow">Highlight 01</p>
        <h3>Bottle-shaped silhouette</h3>
        <p class="launch-preview__body">The form reads as a tabletop object first, which is why the page leads with shape and presence rather than hype-driven performance language.</p>
      </article>

      <article class="launch-preview__card">
        <p class="launch-preview__eyebrow">Highlight 02</p>
        <h3>Copper body</h3>
        <p class="launch-preview__body">Material is described conservatively. The page stays with copper body and the non-silver-lined version until review confirms anything more specific.</p>
      </article>

      <article class="launch-preview__card">
        <p class="launch-preview__eyebrow">Highlight 03</p>
        <h3>Clear boundaries</h3>
        <p class="launch-preview__body">This is a one-product preview surface. No variants, bundles, review widgets, or recommendation clutter are used to simulate a live catalog.</p>
      </article>
    </div>

    <div class="preview-product__detail-grid">
      <section class="launch-preview__surface preview-product__section">
        <div class="preview-product__section-copy">
          <p class="launch-preview__eyebrow">Specs Snapshot</p>
          <h2 class="launch-preview__title launch-preview__title--md">Catalog-listed details, kept in view.</h2>
          <p class="launch-preview__lead">Every field stays labeled so listed information is not mistaken for measured or sample-verified data.</p>
        </div>
        <table class="launch-preview__table">
          <tbody>
            <tr>
              <th>Version</th>
              <td>Non-silver-lined</td>
              <td class="preview-product__spec-status"><span class="launch-preview__chip launch-preview__chip--sage">Pending sample review</span></td>
            </tr>
            <tr>
              <th>Capacity</th>
              <td>500 cc</td>
              <td class="preview-product__spec-status"><span class="launch-preview__chip launch-preview__chip--sage">Catalog-listed</span></td>
            </tr>
            <tr>
              <th>Opening diameter</th>
              <td>5 cm</td>
              <td class="preview-product__spec-status"><span class="launch-preview__chip launch-preview__chip--sage">Catalog-listed</span></td>
            </tr>
            <tr>
              <th>Base diameter</th>
              <td>6.1 cm</td>
              <td class="preview-product__spec-status"><span class="launch-preview__chip launch-preview__chip--sage">Catalog-listed</span></td>
            </tr>
            <tr>
              <th>Height</th>
              <td>15.6 cm</td>
              <td class="preview-product__spec-status"><span class="launch-preview__chip launch-preview__chip--sage">Catalog-listed</span></td>
            </tr>
            <tr>
              <th>Handle and knob</th>
              <td>Catalog-listed material</td>
              <td class="preview-product__spec-status"><span class="launch-preview__chip launch-preview__chip--sage">Pending sample review</span></td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="launch-preview__surface preview-product__section">
        <div class="preview-product__section-copy">
          <p class="launch-preview__eyebrow">Transparency</p>
          <h2 class="launch-preview__title launch-preview__title--md">Why this page stays quiet on launch claims.</h2>
          <p class="launch-preview__lead">The preview is designed to explain the piece without overstating what has not yet been verified.</p>
        </div>
        <div class="launch-preview__body">
          <p>What can be shown now is the object itself, the non-silver-lined version, and the listed dimensions currently available in the catalog source.</p>
          <p>What stays offstage until review is any statement that would read like a performance promise, a safety claim, or a live commerce promise.</p>
          <ul>
            <li>No silver-lining or 999 silver language</li>
            <li>No safety, certification, or inspection claims</li>
            <li>No preorder, waitlist, or launch countdown framing</li>
          </ul>
        </div>
      </section>
    </div>

    <section class="launch-preview__surface preview-product__faq launch-preview__faq">
      <p class="launch-preview__eyebrow">FAQ</p>
      <h2 class="launch-preview__title launch-preview__title--md">Questions the page should answer without friction.</h2>
      <div class="preview-product__faq-grid">
        <div>
          <details>
            <summary>Can I buy it now?</summary>
            <p>No. This preview is notify-only for now, so pricing and checkout are not live.</p>
          </details>
          <details>
            <summary>Is this a preorder or waitlist?</summary>
            <p>No. Signing up only means you want product updates. It does not hold inventory or reserve a place.</p>
          </details>
          <details>
            <summary>Is this the silver-lined version?</summary>
            <p>No. This preview is for the non-silver-lined version.</p>
          </details>
        </div>
        <div>
          <details>
            <summary>Are the specs final?</summary>
            <p>Not yet. The listed dimensions are shown as catalog-listed details and remain pending sample review.</p>
          </details>
          <details>
            <summary>Are these final product photos?</summary>
            <p>No. The page uses reference imagery or placeholders until approved photography is ready.</p>
          </details>
          <details>
            <summary>What does the email sign-up do?</summary>
            <p>It signs you up for updates on this product only. It is not a purchase commitment.</p>
          </details>
        </div>
      </div>
      <p class="preview-product__faq-link"><a href="/pages/faq">View the full FAQ</a></p>
    </section>
  </div>
</section>
