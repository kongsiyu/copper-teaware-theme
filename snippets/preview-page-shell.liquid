{% liquid
  assign shell_title = title
  if shell_title == blank
    assign shell_title = page_title
  endif

  assign shell_body = body_html
  if page_content != blank
    assign shell_body = page_content
  endif
%}

{% render 'preview-launch-theme' %}

<style>
  .preview-doc {
    padding: 40px 0 72px;
  }

  .preview-doc__container {
    width: min(var(--lp-max), calc(100% - 32px));
    margin: 0 auto;
  }

  .preview-doc__hero {
    margin-bottom: 24px;
    padding: 30px;
  }

  .preview-doc__intro {
    max-width: 58ch;
  }

  .preview-doc__layout {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.85fr);
    align-items: start;
  }

  .preview-doc__layout.is-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .preview-doc__main,
  .preview-doc__aside,
  .preview-doc__cta {
    padding: 30px;
  }

  .preview-doc__main {
    display: grid;
    gap: 16px;
  }

  .preview-doc__main h2,
  .preview-doc__main h3 {
    margin: 0;
    font-family: var(--lp-serif);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .preview-doc__main h2 {
    margin-top: 10px;
    font-size: clamp(28px, 3vw, 38px);
  }

  .preview-doc__main h3 {
    margin-top: 6px;
    font-size: 22px;
  }

  .preview-doc__main p,
  .preview-doc__main li,
  .preview-doc__aside p,
  .preview-doc__aside li {
    font-size: 16px;
    line-height: 1.75;
  }

  .preview-doc__main p,
  .preview-doc__aside p,
  .preview-doc__aside ul,
  .preview-doc__main ul,
  .preview-doc__main ol,
  .preview-doc__main table,
  .preview-doc__main details {
    margin: 0 0 18px;
  }

  .preview-doc__main ul,
  .preview-doc__main ol,
  .preview-doc__aside ul {
    padding-left: 20px;
  }

  .preview-doc__main a,
  .preview-doc__aside a,
  .preview-doc__cta a {
    color: var(--lp-accent);
  }

  .preview-doc__main table {
    width: 100%;
    border-collapse: collapse;
  }

  .preview-doc__main th,
  .preview-doc__main td {
    border-top: 1px solid var(--lp-line);
    padding: 14px 0;
    text-align: left;
    vertical-align: top;
  }

  .preview-doc__main tr:first-child th,
  .preview-doc__main tr:first-child td {
    border-top: 0;
    padding-top: 0;
  }

  .preview-doc__main th {
    width: 30%;
    padding-right: 16px;
    font-weight: 600;
  }

  .preview-doc__main details {
    padding: 16px 0;
    background: transparent;
    border: 0;
    border-top: 1px solid var(--lp-line);
  }

  .preview-doc__main summary {
    cursor: pointer;
    font-weight: 700;
  }

  .preview-doc__main summary + p {
    margin-top: 12px;
  }

  .preview-doc__aside {
    display: grid;
    gap: 16px;
  }

  .preview-doc__aside h2 {
    margin: 0;
    font-family: var(--lp-serif);
    font-size: 24px;
    line-height: 1.15;
  }

  .preview-doc__tag {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    margin: 0 8px 8px 0;
    padding: 0 14px;
    border: 1px solid var(--lp-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    color: var(--lp-accent-strong);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .preview-doc__cta {
    margin-top: 24px;
    display: grid;
    gap: 14px;
  }

  .preview-doc__cta h2 {
    margin: 0;
    font-family: var(--lp-serif);
    font-size: clamp(26px, 3vw, 34px);
    line-height: 1.15;
  }

  .preview-doc__cta p {
    margin: 0;
    color: var(--lp-muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .preview-doc__cta .button {
    display: inline-block;
    width: fit-content;
    min-height: 48px;
    padding: 12px 22px;
    border-radius: 999px;
    background: var(--lp-accent);
    color: #fff;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .preview-doc {
      padding: 28px 0 56px;
    }

    .preview-doc__container {
      width: min(var(--lp-max), calc(100% - 24px));
    }

    .preview-doc__hero,
    .preview-doc__main,
    .preview-doc__aside,
    .preview-doc__cta {
      padding: 22px;
    }

    .preview-doc__layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .preview-doc__main th,
    .preview-doc__main td {
      display: block;
      width: 100%;
    }
  }
</style>

<div class="preview-doc">
  <div class="preview-doc__container">
    <header class="launch-preview__surface preview-doc__hero">
      {%- if eyebrow != blank -%}
        <p class="launch-preview__eyebrow">{{ eyebrow }}</p>
      {%- endif -%}
      <h1 class="launch-preview__title launch-preview__title--lg">{{ shell_title }}</h1>
      {%- if intro != blank -%}
        <p class="launch-preview__lead preview-doc__intro">{{ intro }}</p>
      {%- endif -%}
    </header>

    <div class="preview-doc__layout{% if aside_html == blank %} is-single{% endif %}">
      <div class="launch-preview__surface preview-doc__main">
        {{ shell_body }}
      </div>

      {%- if aside_html != blank -%}
        <aside class="launch-preview__surface preview-doc__aside">
          {%- if aside_title != blank -%}
            <h2>{{ aside_title }}</h2>
          {%- endif -%}
          {{ aside_html }}
        </aside>
      {%- endif -%}
    </div>

    {%- if cta_title != blank or cta_text != blank -%}
      <section class="launch-preview__surface preview-doc__cta">
        {%- if cta_title != blank -%}
          <h2>{{ cta_title }}</h2>
        {%- endif -%}
        {%- if cta_text != blank -%}
          <p>{{ cta_text }}</p>
        {%- endif -%}
        {%- if cta_label != blank and cta_link != blank -%}
          <a class="button" href="{{ cta_link }}">{{ cta_label }}</a>
        {%- endif -%}
      </section>
    {%- endif -%}
  </div>
</div>
