{% liquid
  assign shell_title = title
  if shell_title == blank
    assign shell_title = page_title
  endif

  assign shell_body = body_html
  if page_content != blank
    assign shell_body = page_content
  endif
%}

<style>
  .preview-doc {
    --preview-bg: #f5efe6;
    --preview-card: #fff9f1;
    --preview-text: #2b211a;
    --preview-muted: #6f6258;
    --preview-line: #d8c7b5;
    --preview-accent: #4d3727;
    --preview-tag: #496b5d;
    background: linear-gradient(180deg, #f8f2ea 0%, #f5efe6 100%);
    color: var(--preview-text);
    padding: 48px 20px 72px;
  }

  .preview-doc__container {
    margin: 0 auto;
    max-width: 1120px;
  }

  .preview-doc__hero {
    margin-bottom: 28px;
    padding: 28px;
    background: rgba(255, 249, 241, 0.92);
    border: 1px solid var(--preview-line);
  }

  .preview-doc__eyebrow {
    margin: 0 0 10px;
    color: var(--preview-tag);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .preview-doc__hero h1 {
    margin: 0;
    font-size: clamp(32px, 5vw, 54px);
    line-height: 1.08;
  }

  .preview-doc__intro {
    margin: 16px 0 0;
    max-width: 760px;
    color: var(--preview-muted);
    font-size: 18px;
    line-height: 1.7;
  }

  .preview-doc__layout {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
    align-items: start;
  }

  .preview-doc__layout.is-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .preview-doc__main,
  .preview-doc__aside,
  .preview-doc__cta {
    background: rgba(255, 249, 241, 0.92);
    border: 1px solid var(--preview-line);
  }

  .preview-doc__main {
    padding: 28px;
  }

  .preview-doc__main h2,
  .preview-doc__main h3 {
    margin: 0 0 14px;
    line-height: 1.25;
  }

  .preview-doc__main h2 {
    margin-top: 28px;
    font-size: 28px;
  }

  .preview-doc__main h2:first-child {
    margin-top: 0;
  }

  .preview-doc__main h3 {
    margin-top: 22px;
    font-size: 20px;
  }

  .preview-doc__main p,
  .preview-doc__main li,
  .preview-doc__aside p,
  .preview-doc__aside li {
    color: var(--preview-text);
    font-size: 16px;
    line-height: 1.75;
  }

  .preview-doc__main p,
  .preview-doc__aside p,
  .preview-doc__aside ul,
  .preview-doc__main ul,
  .preview-doc__main ol,
  .preview-doc__main table,
  .preview-doc__main details {
    margin: 0 0 18px;
  }

  .preview-doc__main ul,
  .preview-doc__main ol,
  .preview-doc__aside ul {
    padding-left: 20px;
  }

  .preview-doc__main a,
  .preview-doc__aside a,
  .preview-doc__cta a {
    color: var(--preview-accent);
  }

  .preview-doc__main table {
    width: 100%;
    border-collapse: collapse;
  }

  .preview-doc__main th,
  .preview-doc__main td {
    border: 1px solid var(--preview-line);
    padding: 12px 14px;
    text-align: left;
    vertical-align: top;
  }

  .preview-doc__main th {
    width: 30%;
    background: #f3eadf;
  }

  .preview-doc__main details {
    padding: 14px 16px;
    background: #f7f3ee;
    border: 1px solid var(--preview-line);
  }

  .preview-doc__main summary {
    cursor: pointer;
    font-weight: 700;
  }

  .preview-doc__main summary + p {
    margin-top: 12px;
  }

  .preview-doc__aside {
    padding: 24px;
  }

  .preview-doc__aside h2 {
    margin: 0 0 14px;
    font-size: 20px;
  }

  .preview-doc__tag {
    display: inline-block;
    margin: 0 8px 10px 0;
    padding: 6px 10px;
    border: 1px solid var(--preview-line);
    color: var(--preview-tag);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .preview-doc__cta {
    margin-top: 24px;
    padding: 24px 28px;
  }

  .preview-doc__cta h2 {
    margin: 0 0 10px;
    font-size: 24px;
  }

  .preview-doc__cta p {
    margin: 0;
    color: var(--preview-muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .preview-doc__cta .button {
    display: inline-block;
    margin-top: 16px;
    padding: 12px 18px;
    background: var(--preview-accent);
    color: #fff;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .preview-doc {
      padding: 32px 16px 56px;
    }

    .preview-doc__hero,
    .preview-doc__main,
    .preview-doc__aside,
    .preview-doc__cta {
      padding: 20px;
    }

    .preview-doc__layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .preview-doc__main th,
    .preview-doc__main td {
      display: block;
      width: 100%;
    }
  }
</style>

<div class="preview-doc">
  <div class="preview-doc__container">
    <header class="preview-doc__hero">
      {%- if eyebrow != blank -%}
        <p class="preview-doc__eyebrow">{{ eyebrow }}</p>
      {%- endif -%}
      <h1>{{ shell_title }}</h1>
      {%- if intro != blank -%}
        <p class="preview-doc__intro">{{ intro }}</p>
      {%- endif -%}
    </header>

    <div class="preview-doc__layout{% if aside_html == blank %} is-single{% endif %}">
      <div class="preview-doc__main">
        {{ shell_body }}
      </div>

      {%- if aside_html != blank -%}
        <aside class="preview-doc__aside">
          {%- if aside_title != blank -%}
            <h2>{{ aside_title }}</h2>
          {%- endif -%}
          {{ aside_html }}
        </aside>
      {%- endif -%}
    </div>

    {%- if cta_title != blank or cta_text != blank -%}
      <section class="preview-doc__cta">
        {%- if cta_title != blank -%}
          <h2>{{ cta_title }}</h2>
        {%- endif -%}
        {%- if cta_text != blank -%}
          <p>{{ cta_text }}</p>
        {%- endif -%}
        {%- if cta_label != blank and cta_link != blank -%}
          <a class="button" href="{{ cta_link }}">{{ cta_label }}</a>
        {%- endif -%}
      </section>
    {%- endif -%}
  </div>
</div>
