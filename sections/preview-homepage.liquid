{% liquid
  assign notify_tag = 'notify-copper-bottle-pour-over-kettle'
  assign stage_note = section.settings.stage_note | default: 'This launch preview introduces the non-silver-lined version with clearly labeled catalog details only.'
  assign hero_heading = section.settings.hero_heading | default: 'One Copper Kettle, Shown With Clear Boundaries'
  assign hero_subheading = section.settings.hero_subheading | default: 'This preview focuses on the non-silver-lined version and catalog-listed specs while sample details are still under review.'
  assign hero_body = section.settings.hero_body | default: 'This page is a product preview for the non-silver-lined version. Pricing, availability, and sample-verified details will only be added after review.'
  assign hero_microcopy = section.settings.hero_microcopy | default: 'For product updates only. No reservation or purchase commitment.'
  assign hero_primary_label = section.settings.hero_primary_label | default: 'Notify Me'
  assign hero_primary_link = section.settings.hero_primary_link | default: '#notify-cta'
  assign hero_secondary_label = section.settings.hero_secondary_label | default: 'See Product Details'
  assign hero_secondary_link = section.settings.hero_secondary_link | default: '/pages/copper-kettle-preview'
  assign hero_image_status = section.settings.hero_image_status | default: 'Reference image / placeholder'
  assign story_heading = section.settings.story_heading | default: 'A bottle-shaped silhouette, shown as an object first.'
  assign story_body = section.settings.story_body | default: 'The form is the first reason to slow down. It reads more like a tabletop object than a gear-first tool, which is exactly why the page keeps the framing calm and specific.'
  assign story_body_secondary = section.settings.story_body_secondary | default: 'For now, the frontstage surface stays with what can be stated clearly: copper body, non-silver-lined version, and catalog-listed dimensions pending sample review.'
  assign story_image_status = section.settings.story_image_status | default: 'Reference crop / silhouette'
  assign notify_heading = section.settings.notify_heading | default: 'Stay close to the next update.'
  assign notify_body = section.settings.notify_body | default: 'Leave your email if you want product updates when review-backed details are ready to open up. This is not a preorder or waitlist.'
  assign notify_fineprint = section.settings.notify_fineprint | default: 'Updates only. No preorder, waitlist, or purchase commitment.'
%}

{% render 'preview-launch-theme' %}

<style>
  #shopify-section-{{ section.id }} .preview-home {
    padding: 40px 0 82px;
  }

  #shopify-section-{{ section.id }} .preview-home__stage,
  #shopify-section-{{ section.id }} .preview-home__hero,
  #shopify-section-{{ section.id }} .preview-home__proof,
  #shopify-section-{{ section.id }} .preview-home__story,
  #shopify-section-{{ section.id }} .preview-home__notify,
  #shopify-section-{{ section.id }} .preview-home__faq {
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .preview-home__stage {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) auto;
    gap: 18px;
    align-items: center;
    padding: 20px 24px;
  }

  #shopify-section-{{ section.id }} .preview-home__stage-copy {
    display: grid;
    gap: 14px;
  }

  #shopify-section-{{ section.id }} .preview-home__stage-copy p {
    margin: 0;
    color: var(--lp-muted);
    font-size: 15px;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .preview-home__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(340px, 0.98fr);
    gap: 24px;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .preview-home__hero-copy,
  #shopify-section-{{ section.id }} .preview-home__hero-media,
  #shopify-section-{{ section.id }} .preview-home__specs-panel,
  #shopify-section-{{ section.id }} .preview-home__faq-panel {
    padding: 30px;
  }

  #shopify-section-{{ section.id }} .preview-home__hero-copy {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  #shopify-section-{{ section.id }} .preview-home__hero-copy p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .preview-home__hero-media .launch-preview__media-frame {
    min-height: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .preview-home__hero-media {
    min-height: 560px;
  }

  #shopify-section-{{ section.id }} .preview-home__hero-caption {
    margin-top: 14px;
  }

  #shopify-section-{{ section.id }} .preview-home__reasons {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .preview-home__proof {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 24px;
    padding: 28px 30px;
  }

  #shopify-section-{{ section.id }} .preview-home__proof-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  #shopify-section-{{ section.id }} .preview-home__proof-copy p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .preview-home__story,
  #shopify-section-{{ section.id }} .preview-home__notify,
  #shopify-section-{{ section.id }} .preview-home__faq {
    display: grid;
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .preview-home__story {
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .preview-home__story-media,
  #shopify-section-{{ section.id }} .preview-home__story-copy {
    padding: 30px;
  }

  #shopify-section-{{ section.id }} .preview-home__story-media .launch-preview__media-frame {
    min-height: 420px;
  }

  #shopify-section-{{ section.id }} .preview-home__story-copy {
    display: grid;
    gap: 16px;
    align-content: start;
  }

  #shopify-section-{{ section.id }} .preview-home__story-copy p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .preview-home__story-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 4px;
  }

  #shopify-section-{{ section.id }} .preview-home__bottom {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 24px;
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .preview-home__specs-panel,
  #shopify-section-{{ section.id }} .preview-home__faq-panel {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  #shopify-section-{{ section.id }} .preview-home__specs-panel p,
  #shopify-section-{{ section.id }} .preview-home__faq-panel p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .preview-home__spec-status {
    padding-left: 18px;
  }

  #shopify-section-{{ section.id }} .preview-home__faq-link {
    margin-top: 8px;
  }

  #shopify-section-{{ section.id }} .preview-home__notify {
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.88fr);
    padding: 30px;
  }

  #shopify-section-{{ section.id }} .preview-home__notify-copy,
  #shopify-section-{{ section.id }} .preview-home__notify-form-wrap {
    display: grid;
    gap: 16px;
    align-content: start;
  }

  #shopify-section-{{ section.id }} .preview-home__notify-copy p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .preview-home__notify-form {
    display: grid;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .preview-home__notify-messages {
    display: grid;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .preview-home__message {
    margin: 0;
    font-size: 13px;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .preview-home__message.is-success {
    color: #2f6f3e;
  }

  #shopify-section-{{ section.id }} .preview-home__message.is-error {
    color: #a94442;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .preview-home__stage,
    #shopify-section-{{ section.id }} .preview-home__hero,
    #shopify-section-{{ section.id }} .preview-home__proof,
    #shopify-section-{{ section.id }} .preview-home__story,
    #shopify-section-{{ section.id }} .preview-home__bottom,
    #shopify-section-{{ section.id }} .preview-home__notify {
      grid-template-columns: minmax(0, 1fr);
    }

    #shopify-section-{{ section.id }} .preview-home__reasons {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .preview-home__hero-media {
      min-height: 380px;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .preview-home {
      padding: 28px 0 56px;
    }

    #shopify-section-{{ section.id }} .preview-home__hero-copy,
    #shopify-section-{{ section.id }} .preview-home__hero-media,
    #shopify-section-{{ section.id }} .preview-home__story-media,
    #shopify-section-{{ section.id }} .preview-home__story-copy,
    #shopify-section-{{ section.id }} .preview-home__specs-panel,
    #shopify-section-{{ section.id }} .preview-home__faq-panel,
    #shopify-section-{{ section.id }} .preview-home__notify {
      padding: 22px;
    }

    #shopify-section-{{ section.id }} .preview-home__proof,
    #shopify-section-{{ section.id }} .preview-home__stage {
      padding: 22px;
    }

    #shopify-section-{{ section.id }} .preview-home__reasons {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

<section class="launch-preview preview-home">
  <div class="launch-preview__container">
    <div class="launch-preview__surface launch-preview__surface--tight preview-home__stage">
      <div class="preview-home__stage-copy">
        <div class="launch-preview__chip-row">
          <span class="launch-preview__chip launch-preview__chip--accent">Product Preview</span>
          <span class="launch-preview__chip">Notify Only</span>
          <span class="launch-preview__chip launch-preview__chip--sage">Sample Review Pending</span>
        </div>
        <p>{{ stage_note }}</p>
      </div>
      <a class="launch-preview__button launch-preview__button--secondary" href="/pages/preview-stage">Preview Terms</a>
    </div>

    <div class="preview-home__hero">
      <div class="launch-preview__surface preview-home__hero-copy">
        <p class="launch-preview__eyebrow">Single-Product Launch Preview</p>
        <h1 class="launch-preview__title launch-preview__title--xl">{{ hero_heading }}</h1>
        <p class="launch-preview__lead">{{ hero_subheading }}</p>
        <p class="launch-preview__body">{{ hero_body }}</p>
        <div class="launch-preview__chip-row">
          <span class="launch-preview__chip">Non-silver-lined version</span>
          <span class="launch-preview__chip launch-preview__chip--sage">Catalog-listed specs</span>
          <span class="launch-preview__chip launch-preview__chip--sand">Single-SKU focus</span>
        </div>
        <div class="launch-preview__button-row">
          <a class="launch-preview__button" href="{{ hero_primary_link }}">{{ hero_primary_label }}</a>
          <a class="launch-preview__button launch-preview__button--secondary" href="{{ hero_secondary_link }}">{{ hero_secondary_label }}</a>
        </div>
        <p class="launch-preview__fineprint">{{ hero_microcopy }}</p>
      </div>

      <div class="launch-preview__surface preview-home__hero-media">
        <div class="launch-preview__media-frame">
          <span class="launch-preview__badge">{{ hero_image_status }}</span>
          {%- if section.settings.hero_image != blank -%}
            <picture>
              {%- if section.settings.hero_image_mobile != blank -%}
                <source media="(max-width: 749px)" srcset="{{ section.settings.hero_image_mobile | image_url: width: 960 }}">
              {%- endif -%}
              {{ section.settings.hero_image | image_url: width: 1600 | image_tag: alt: 'Copper pour-over kettle hero reference image', loading: 'lazy' }}
            </picture>
          {%- else -%}
            <div class="launch-preview__placeholder">
              <div>
                <strong>Hero image slot is ready.</strong>
                <p style="margin: 10px 0 0;">Upload separate desktop and mobile crops when they are available. Until then, keep the image explicitly labeled as reference or placeholder.</p>
              </div>
            </div>
          {%- endif -%}
        </div>
        <p class="launch-preview__fineprint preview-home__hero-caption">Reference imagery stays labeled on every viewport. No unlabeled lifestyle image should be used before review-backed photography is ready.</p>
      </div>
    </div>

    <div class="launch-preview__card-grid preview-home__reasons">
      {%- for block in section.blocks -%}
        {%- if block.type == 'reason' -%}
          <article class="launch-preview__card" {{ block.shopify_attributes }}>
            <p class="launch-preview__eyebrow">Reason {{ forloop.index }}</p>
            <h3>{{ block.settings.title }}</h3>
            <p class="launch-preview__body">{{ block.settings.copy }}</p>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="launch-preview__surface preview-home__proof">
      <div class="preview-home__proof-copy">
        <p class="launch-preview__eyebrow">Proof Strip</p>
        <h2 class="launch-preview__title launch-preview__title--md">Shown with clear boundaries.</h2>
        <p class="launch-preview__lead">This preview leads with the object, then the evidence, and only then the update sign-up.</p>
      </div>
      <div class="launch-preview__chip-row">
        {%- for block in section.blocks -%}
          {%- if block.type == 'proof' -%}
            {%- assign proof_tone = block.settings.tone | default: 'default' -%}
            <span class="launch-preview__chip{% if proof_tone == 'sage' %} launch-preview__chip--sage{% elsif proof_tone == 'accent' %} launch-preview__chip--accent{% elsif proof_tone == 'sand' %} launch-preview__chip--sand{% endif %}" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="preview-home__story">
      <div class="launch-preview__surface preview-home__story-media">
        <div class="launch-preview__media-frame">
          <span class="launch-preview__badge">{{ story_image_status }}</span>
          {%- if section.settings.artifact_image != blank -%}
            {{ section.settings.artifact_image | image_url: width: 1400 | image_tag: alt: 'Copper pour-over kettle reference crop', loading: 'lazy' }}
          {%- else -%}
            <div class="launch-preview__placeholder">
              <div>
                <strong>Story image slot is ready.</strong>
                <p style="margin: 10px 0 0;">Use a silhouette crop, a catalog detail, or a clearly labeled reference image. Avoid polished faux-final imagery.</p>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="launch-preview__surface preview-home__story-copy">
        <p class="launch-preview__eyebrow">Object Story</p>
        <h2 class="launch-preview__title launch-preview__title--md">{{ story_heading }}</h2>
        <p class="launch-preview__body">{{ story_body }}</p>
        <p class="launch-preview__body">{{ story_body_secondary }}</p>
        <div class="preview-home__story-links">
          <a href="/pages/copper-kettle-preview">Read the full product details</a>
          <a href="/pages/faq">See the current FAQ</a>
        </div>
      </div>
    </div>

    <div class="preview-home__bottom">
      <section class="launch-preview__surface preview-home__specs-panel">
        <p class="launch-preview__eyebrow">Specs Snapshot</p>
        <h2 class="launch-preview__title launch-preview__title--md">The fields that can be shown now.</h2>
        <p class="launch-preview__lead">Every line stays labeled, so catalog information is not mistaken for sample-verified detail.</p>
        <table class="launch-preview__table">
          <tbody>
            {%- for block in section.blocks -%}
              {%- if block.type == 'spec' -%}
                <tr {{ block.shopify_attributes }}>
                  <th>{{ block.settings.label }}</th>
                  <td>{{ block.settings.value }}</td>
                  <td class="preview-home__spec-status">
                    <span class="launch-preview__chip launch-preview__chip--sage">{{ block.settings.status }}</span>
                  </td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </section>

      <section class="launch-preview__surface preview-home__faq-panel launch-preview__faq">
        <p class="launch-preview__eyebrow">FAQ Snapshot</p>
        <h2 class="launch-preview__title launch-preview__title--md">Questions the page should answer early.</h2>
        <p class="launch-preview__lead">The goal is clarity, not sales pressure.</p>
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
            <details {{ block.shopify_attributes }}>
              <summary>{{ block.settings.question }}</summary>
              <p>{{ block.settings.answer }}</p>
            </details>
          {%- endif -%}
        {%- endfor -%}
        <p class="preview-home__faq-link"><a href="/pages/faq">View the full FAQ</a></p>
      </section>
    </div>

    <div class="launch-preview__surface preview-home__notify" id="notify-cta">
      <div class="preview-home__notify-copy">
        <p class="launch-preview__eyebrow">Notify CTA</p>
        <h2 class="launch-preview__title launch-preview__title--md">{{ notify_heading }}</h2>
        <p class="launch-preview__lead">{{ notify_body }}</p>
        <div class="launch-preview__chip-row">
          <span class="launch-preview__chip launch-preview__chip--accent">Updates Only</span>
          <span class="launch-preview__chip">No Preorder</span>
          <span class="launch-preview__chip">No Waitlist</span>
        </div>
      </div>

      <div class="preview-home__notify-form-wrap">
        {%- form 'customer', class: 'preview-home__notify-form' -%}
          <input type="hidden" name="contact[tags]" value="{{ notify_tag }}">
          <div class="launch-preview__form-row">
            <input class="launch-preview__input" type="email" name="contact[email]" placeholder="Email for product updates" required>
            <button type="submit" class="launch-preview__button">Notify Me</button>
          </div>
          <p class="launch-preview__fineprint">{{ notify_fineprint }}</p>
          <div class="preview-home__notify-messages">
            {%- if form.posted_successfully? -%}
              <p class="preview-home__message is-success">You are signed up for product updates. This does not create a reservation or purchase commitment.</p>
            {%- endif -%}
            {%- if form.errors -%}
              <p class="preview-home__message is-error">Please enter a valid email address before submitting the form.</p>
            {%- endif -%}
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

