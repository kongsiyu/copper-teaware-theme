{% comment %}
  Public preview route for the kettle while the underlying Shopify product
  remains draft-locked. Use this page as the external-facing single-product
  dossier during preview-only + notify-only.
{% endcomment %}

{% capture default_preview_description_html %}
  <p>This page shows the non-silver-lined version as a structured product preview, with reference imagery and catalog-listed details kept clearly labeled.</p>
  <p>It is built to explain the object first, then the evidence that can be shown now, and finally the low-commitment sign-up for product updates.</p>
  <p>Pricing, availability, and review-backed details will only appear after sample review is complete.</p>
{% endcapture %}

{% liquid
  assign preview_description_html = default_preview_description_html
  if page.content != blank
    assign preview_description_html = page.content
  endif
%}

<div
  class="preview-product"
  data-preview-surface="public-page"
  data-preview-route="/pages/copper-kettle-preview">
  {% render 'preview-product-dossier',
    preview_title: 'Copper Pour-Over Kettle With a Bottle-Shaped Silhouette',
    material_note: 'Copper body',
    notify_tag: 'notify-copper-bottle-pour-over-kettle',
    preview_description_html: preview_description_html,
    preview_kicker: 'Non-silver-lined version. Catalog-listed specs. Pending sample review.',
    media_badge: 'Reference image / placeholder',
    notify_anchor_id: 'notify-interest'
  %}
</div>
