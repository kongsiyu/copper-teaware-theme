{% comment %}
  product-copper-kettle.liquid
  Notify-only preview template for the draft-locked kettle product.
{% endcomment %}

{%- assign sample_verified = false -%}
{%- assign preview_title = 'Copper Pour-Over Kettle With a Bottle-Shaped Silhouette' -%}
{%- assign material_note = 'Copper body' -%}
{%- assign notify_tag = 'notify-copper-bottle-pour-over-kettle' -%}
{% capture default_preview_description_html %}
  <p>This preview centers on the non-silver-lined version and the catalog-listed dimensions currently available to share.</p>
  <p>It is designed to explain the object, the boundaries, and the only live action now: product updates.</p>
  <p>Pricing, availability, and sample-verified details will be added only after review.</p>
{% endcapture %}

<div
  class="preview-product"
  data-sample-verified="{{ sample_verified }}"
  data-preview-commerce="{% unless sample_verified %}notify-only{% else %}enabled-after-ceo-approval{% endunless %}"
  data-structured-offers="{% unless sample_verified %}disabled{% else %}eligible{% endunless %}">
  {% render 'preview-product-dossier',
    preview_title: preview_title,
    material_note: material_note,
    notify_tag: notify_tag,
    preview_description_html: default_preview_description_html,
    preview_featured_image: product.featured_image,
    media_alt: product.featured_image.alt,
    preview_kicker: 'Non-silver-lined version. Catalog-listed specs. Pending sample review.',
    media_badge: 'Reference image / placeholder',
    notify_anchor_id: 'notify-interest'
  %}
</div>
