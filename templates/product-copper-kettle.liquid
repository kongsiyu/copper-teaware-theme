{% comment %}
  product-copper-kettle.liquid
  占位模板 — 零送样阶段使用，样品到手后替换实拍图和最终文案
  sample_verified = false 时只允许 notify-only 资料预览
{% endcomment %}

{%- assign sample_verified = false -%}
{%- assign material_note = product.metafields.product_info.material_note | default: '紫铜壶体，非银内壁版本' -%}
{%- assign notify_tag = 'notify-copper-bottle-pour-over-kettle' -%}
{% capture default_preview_description_html %}
  <div class="default-preview-copy">
    <p>这把紫铜水瓶手冲咖啡壶当前处于资料预览阶段。当前可公开信息包括紫铜壶体、非银内壁版本、水瓶型轮廓，以及图册资料显示的基础规格。</p>
    <p>当前页面只用于资料预览和到货通知，不开放正式下单。</p>
    <p>后续如这款产品有公开更新，我们会补充实拍、规格复核结果和页面状态说明。</p>
  </div>
{% endcapture %}

{% liquid
  assign preview_description_html = product.description
  if preview_description_html == blank
    assign preview_description_html = default_preview_description_html
  endif
%}

<div
  class="preview-product"
  data-sample-verified="{{ sample_verified }}"
  data-preview-commerce="{% unless sample_verified %}notify-only{% else %}enabled-after-ceo-approval{% endunless %}"
  data-structured-offers="{% unless sample_verified %}disabled{% else %}eligible{% endunless %}">
  {% render 'preview-product-dossier',
    preview_title: product.title,
    material_note: material_note,
    notify_tag: notify_tag,
    preview_description_html: preview_description_html,
    preview_featured_image: product.featured_image,
    media_alt: product.featured_image.alt,
    notify_anchor_id: 'notify-interest'
  %}
</div>
