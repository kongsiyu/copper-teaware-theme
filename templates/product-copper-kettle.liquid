{% comment %}
  product-copper-kettle.liquid
  占位模板 — 零送样阶段使用，样品到手后替换实拍图和最终文案
  sample_verified = false 时只允许 notify-only 资料预览
{% endcomment %}

{%- assign sample_verified_value = product.metafields.product_info.sample_verified.value | default: false -%}
{%- assign sample_verified = false -%}
{%- if sample_verified_value == true or sample_verified_value == 'true' -%}
  {%- assign sample_verified = true -%}
{%- endif -%}

<div class="product-page" data-sample-verified="{{ sample_verified }}">

  {%- unless sample_verified -%}
    <div class="sample-pending-banner" style="background:#fff3cd;padding:12px;margin-bottom:16px;border-left:4px solid #ffc107;">
      ⚠️ 资料预览：样品待验收，目前只开放到货通知，不开放正式下单
    </div>
  {%- endunless -%}

  <div class="product-media">
    {%- if product.featured_image -%}
      {{ product.featured_image | image_url: width: 800 | image_tag: alt: product.featured_image.alt }}
    {%- else -%}
      <div class="image-placeholder" style="background:#f5f0eb;aspect-ratio:1;display:flex;align-items:center;justify-content:center;color:#999;">
        实拍图待上传（样品到手后）
      </div>
    {%- endif -%}
    {%- unless sample_verified -%}
      <p class="media-note" style="margin-top:8px;color:#7a6b5d;font-size:14px;">
        当前展示为资料图或占位图，样品验收后替换为实拍。
      </p>
    {%- endunless -%}
  </div>

  <div class="product-info">
    <h1 class="product-title">{{ product.title }}</h1>

    <div class="product-meta">
      <span class="material-tag">{{ product.metafields.product_info.material_note }}</span>
    </div>
    <p class="sku-lock-note" style="margin:12px 0 0;color:#7a6b5d;">
      当前只围绕这一款推进，不提供版本选择。
    </p>

    <div class="product-price">
      {%- if sample_verified and product.variants.first.price != blank and product.variants.first.price != 0 -%}
        {{ product.variants.first.price | money }}
      {%- else -%}
        <span class="price-pending">价格待样品验收后公布</span>
      {%- endif -%}
    </div>

    {%- if sample_verified -%}
      {%- form 'product', product -%}
        {%- unless product.has_only_default_variant -%}
          <div class="variant-selector">
            {%- for option in product.options_with_values -%}
              <label for="option-{{ forloop.index }}">{{ option.name }}</label>
              <select id="option-{{ forloop.index }}" name="options[{{ option.name }}]">
                {%- for value in option.values -%}
                  <option value="{{ value }}">{{ value }}</option>
                {%- endfor -%}
              </select>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <button type="submit"
          class="btn-add-to-cart"
          {%- unless product.available -%}disabled{%- endunless -%}>
          {%- if product.available -%}加入购物车{%- else -%}暂时缺货{%- endif -%}
        </button>
      {%- endform -%}
    {%- else -%}
      <div id="notify-interest" class="notify-interest" style="background:#f7f3ee;padding:16px;border:1px solid #dbcbbd;">
        <h3 style="margin-top:0;">到货通知</h3>
        <p style="margin-top:0;">样品验收、定价和正式上架完成后，第一时间通知你。当前不锁定库存，也不承诺价格和发货时间。</p>
        {%- form 'customer' -%}
          <input type="hidden" name="contact[tags]" value="notify-{{ product.handle }}">
          <input
            type="email"
            name="contact[email]"
            placeholder="输入邮箱，获取到货通知"
            required
            style="min-width:240px;padding:10px;border:1px solid #cdbcae;margin-right:8px;">
          <button type="submit" class="btn-notify" style="padding:10px 16px;background:#4d3727;color:#fff;border:0;">
            到货通知我
          </button>
          {%- if form.posted_successfully? -%}
            <p style="margin-bottom:0;color:#2f6f3e;">已收到你的邮箱，正式到货后会发送通知。</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p style="margin-bottom:0;color:#a94442;">请填写有效邮箱后再提交。</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

    <div class="product-description">
      {%- if product.description != blank -%}
        {{ product.description }}
      {%- else -%}
        <p class="copy-pending" style="color:#999;font-style:italic;">文案待补充（运营填写后更新）</p>
      {%- endif -%}
    </div>

    <div class="product-specs">
      <h3>规格参数</h3>
      <table>
        <tr><th>壶体材质</th><td>紫铜（非银内壁版本）</td></tr>
        <tr><th>把手/盖钮</th><td>电木（待样品复核）</td></tr>
        <tr><th>容量</th><td>约 500 cc（图册数据，待样品复核）</td></tr>
      </table>
    </div>
  </div>

</div>
